{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "g++ Build and debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "args": [],
